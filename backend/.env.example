# ───────────────────────────────────────────────────────────
# LLM 配置 — 把這份複製成 backend/.env 並填入 key
# cp backend/.env.example backend/.env
# ───────────────────────────────────────────────────────────

# 選 provider: minimax | openai | local
LLM_PROVIDER=minimax

# ── MiniMax（OpenAI-compatible） ───────────────────────────
MINIMAX_API_KEY=
MINIMAX_API_BASE=https://api.minimax.io
MINIMAX_MODEL=MiniMax-M2.7-highspeed

# ── OpenAI（正牌） ────────────────────────────────────────
# 把上面 LLM_PROVIDER 改成 openai 再填這三行
OPENAI_API_KEY=
OPENAI_API_BASE=https://api.openai.com
OPENAI_MODEL=gpt-4o-mini

# ── Local LLM（vLLM / Ollama / LM Studio 等） ────────────
# 把上面 LLM_PROVIDER 改成 local，填你本地服務的 URL & model 名稱
# 大多本地服務不需真 key，LOCAL_API_KEY 留空也行
LOCAL_API_BASE=http://localhost:8000/v1
LOCAL_API_KEY=
LOCAL_MODEL=gpt-oss-120b
