# ─────────────────────────────────────────────────────────────
# simple_demo backend 環境變數範本
#
# 使用方式：
#   1. cp backend/.env.example backend/.env
#   2. 選一個 provider，填對應欄位
#   3. 啟動 backend（python -m uvicorn app.main:app --port 5488）
#
# backend/.env 已在 .gitignore，不會被推上 GitHub。
# ─────────────────────────────────────────────────────────────

# 選 provider：minimax | openai | local
LLM_PROVIDER=minimax


# ── Option 1: MiniMax 雲端（OpenAI-compatible）─────────────
MINIMAX_API_KEY=sk-...your-minimax-key...
MINIMAX_API_BASE=https://api.minimax.io
MINIMAX_MODEL=MiniMax-M2.7-highspeed


# ── Option 2: OpenAI 正牌 ───────────────────────────────────
# 把 LLM_PROVIDER 改 openai 並填下面三行
OPENAI_API_KEY=sk-...your-openai-key...
OPENAI_API_BASE=https://api.openai.com
OPENAI_MODEL=gpt-4o-mini


# ── Option 3: 本地 / 區網 OpenAI-compatible 服務 ───────────
# 適用：vLLM、Ollama、LM Studio、內部跳板 proxy 等。
# base 要填到 /v1 結尾（例: http://192.168.1.10:8000/v1）。
# 若 proxy 自己處理 token（不驗 key），LOCAL_API_KEY 隨便填字串即可
# ——openai SDK 一定會送 Authorization header，proxy 忽略就好。
LOCAL_API_BASE=http://localhost:8000/v1
LOCAL_API_KEY=EMPTY
LOCAL_MODEL=gpt-oss-120b
